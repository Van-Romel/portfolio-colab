---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);

const base = '/portfolio-colab';
const projectsUrl = locale === 'pt' ? `${base}/projetos/` : `${base}/${locale}/projetos/`;
const contactHash = locale === 'pt' ? `${base}/#contato` : `${base}/${locale}/#contato`;
---

<section id="home" class="hero-section relative min-h-screen flex items-center justify-center pt-20 pb-12 overflow-hidden">

  <!-- LIGHT MODE background -->
  <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-indigo-50/60 to-white dark:hidden"></div>
  <!-- DARK MODE background -->
  <div class="absolute inset-0 bg-gradient-to-br from-slate-950 via-indigo-950 to-slate-900 hidden dark:block"></div>

  <!-- LIGHT MODE orbs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none dark:hidden">
    <div class="glow-orb absolute -top-32 -right-32 h-[500px] w-[500px] rounded-full bg-indigo-200/50 blur-[100px]"></div>
    <div class="glow-orb-2 absolute -bottom-32 -left-32 h-[400px] w-[400px] rounded-full bg-blue-200/40 blur-[80px]"></div>
    <div class="glow-orb-3 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[300px] w-[300px] rounded-full bg-cyan-100/60 blur-[60px]"></div>
  </div>
  <!-- DARK MODE orbs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none hidden dark:block">
    <div class="glow-orb absolute -top-32 -right-32 h-[600px] w-[600px] rounded-full bg-indigo-600/20 blur-[120px]"></div>
    <div class="glow-orb-2 absolute -bottom-32 -left-32 h-[500px] w-[500px] rounded-full bg-blue-600/15 blur-[100px]"></div>
    <div class="glow-orb-3 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[300px] w-[300px] rounded-full bg-cyan-500/10 blur-[80px]"></div>
  </div>

  <!-- Grid pattern overlay (light & dark versions) -->
  <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.04]" style="background-image: linear-gradient(rgba(99,102,241,1) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,1) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Floating code decoration (desktop only, clipped inside section) -->
  <div class="hero-code-block hidden lg:block absolute top-28 right-6 xl:right-12 opacity-0 translate-y-4 transition-all duration-1000 delay-700 max-w-[250px]">
    <div class="rounded-2xl border border-indigo-200/60 dark:border-indigo-500/20 bg-white/90 dark:bg-slate-900/80 backdrop-blur-xl p-5 shadow-xl shadow-indigo-200/30 dark:shadow-indigo-900/30 font-mono text-xs">
      <div class="flex items-center gap-1.5 mb-3">
        <span class="h-2.5 w-2.5 rounded-full bg-red-400/80"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-yellow-400/80"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-green-400/80"></span>
        <span class="ml-2 text-slate-400 text-[10px]">deploy.yml</span>
      </div>
      <div class="space-y-1 leading-relaxed">
        <div><span class="text-indigo-500 dark:text-indigo-400">on</span><span class="text-slate-400">:</span></div>
        <div class="pl-3"><span class="text-blue-500 dark:text-blue-300">push</span><span class="text-slate-400">:</span></div>
        <div class="pl-6"><span class="text-slate-500">branches</span><span class="text-slate-400">: [</span><span class="text-green-600 dark:text-green-300">main</span><span class="text-slate-400">]</span></div>
        <div class="mt-2"><span class="text-indigo-500 dark:text-indigo-400">jobs</span><span class="text-slate-400">:</span></div>
        <div class="pl-3"><span class="text-blue-500 dark:text-blue-300">deploy</span><span class="text-slate-400">:</span></div>
        <div class="pl-6"><span class="text-slate-500">runs-on</span><span class="text-slate-400">: </span><span class="text-green-600 dark:text-green-300">ubuntu-latest</span></div>
        <div class="pl-8 flex items-center gap-1.5 mt-1"><span class="text-green-500">✓</span><span class="text-slate-400 text-[10px]">Build succeeded</span></div>
      </div>
    </div>
  </div>

  <!-- Floating tech stack decoration (desktop only) -->
  <div class="hero-stack-block hidden lg:block absolute bottom-28 left-6 xl:left-12 opacity-0 translate-y-4 transition-all duration-1000 delay-900">
    <div class="rounded-2xl border border-indigo-200/60 dark:border-indigo-500/20 bg-white/90 dark:bg-slate-900/80 backdrop-blur-xl p-4 shadow-xl shadow-indigo-200/30 dark:shadow-indigo-900/30">
      <div class="flex items-center gap-2 mb-3">
        <div class="h-6 w-6 rounded-md bg-gradient-to-br from-indigo-500 to-blue-600 flex items-center justify-center">
          <svg class="h-3.5 w-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </div>
        <span class="text-xs font-semibold text-slate-700 dark:text-slate-300">Tech Stack</span>
      </div>
      <div class="flex flex-wrap gap-1.5">
        {['Kotlin', 'Spring Boot', 'K8s', 'Azure', 'React'].map(tech => (
          <span class="px-2 py-0.5 rounded-md bg-indigo-50 dark:bg-indigo-500/15 border border-indigo-200 dark:border-indigo-500/25 text-indigo-600 dark:text-indigo-300 text-[10px] font-medium">{tech}</span>
        ))}
      </div>
    </div>
  </div>

  <!-- Main content -->
  <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center z-10">

    <!-- Animated badge -->
    <div class="hero-badge inline-flex items-center gap-2.5 rounded-full border border-indigo-300/60 dark:border-indigo-500/30 bg-indigo-50 dark:bg-indigo-500/10 px-5 py-2 text-sm text-indigo-600 dark:text-indigo-300 mb-8 opacity-0">
      <span class="relative flex h-2 w-2 shrink-0">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-400"></span>
      </span>
      {i18n.hero.badge}
    </div>

    <!-- Main heading -->
    <h1 class="hero-title opacity-0">
      <span class="block text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black tracking-tight text-slate-900 dark:text-white leading-none">
        {i18n.hero.title1}
      </span>
      <span class="block mt-3 text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-none bg-gradient-to-r from-indigo-600 to-blue-600 dark:from-indigo-400 dark:via-blue-400 dark:to-cyan-300 bg-clip-text text-transparent">
        {i18n.hero.title2}
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="hero-subtitle mx-auto mt-7 max-w-2xl text-lg sm:text-xl text-slate-600 dark:text-slate-400 leading-relaxed opacity-0">
      {i18n.hero.subtitle}
    </p>

    <!-- Company tagline -->
    <p class="hero-tagline mt-3 text-xs font-semibold uppercase tracking-[0.2em] text-indigo-400 dark:text-indigo-500/70 opacity-0">
      Sena & Carvalho Tech Labs
    </p>

    <!-- CTAs -->
    <div class="hero-ctas mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0">
      <a href={projectsUrl} class="group w-full sm:w-auto inline-flex items-center justify-center gap-2.5 rounded-xl bg-gradient-to-r from-indigo-600 to-blue-600 px-8 py-3.5 text-sm font-semibold text-white shadow-lg shadow-indigo-500/30 hover:shadow-indigo-500/50 transition-all duration-300 hover:-translate-y-0.5 hover:from-indigo-500 hover:to-blue-500">
        {i18n.hero.cta1}
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
      <a href={contactHash} class="group w-full sm:w-auto inline-flex items-center justify-center gap-2.5 rounded-xl border border-slate-300 dark:border-slate-700 bg-white/80 dark:bg-slate-900/60 px-8 py-3.5 text-sm font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 hover:border-indigo-400 dark:hover:border-indigo-500/50 hover:text-indigo-600 dark:hover:text-white transition-all duration-300 hover:-translate-y-0.5 backdrop-blur-sm">
        <svg class="h-4 w-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        {i18n.hero.cta2}
      </a>
    </div>

    <!-- Tech tags row -->
    <div class="hero-tags mt-12 flex flex-wrap items-center justify-center gap-2 opacity-0">
      {['Spring Boot', 'Kubernetes', 'Azure', 'React', 'Angular', 'Docker', 'Kotlin', 'CI/CD'].map(tech => (
        <span class="px-3.5 py-1.5 rounded-full border border-slate-300/80 dark:border-slate-700/80 text-xs font-medium text-slate-500 dark:text-slate-500 hover:border-indigo-400 dark:hover:border-indigo-500/50 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-500/5 transition-all duration-300 cursor-default">
          {tech}
        </span>
      ))}
    </div>

    <!-- Stats row -->
    <div class="hero-stats mt-14 grid grid-cols-3 gap-4 max-w-lg mx-auto opacity-0">
      <div class="text-center">
        <div class="text-2xl font-black bg-gradient-to-r from-indigo-600 to-blue-600 dark:from-indigo-400 dark:to-blue-400 bg-clip-text text-transparent">+50</div>
        <div class="text-xs text-slate-500 dark:text-slate-500 mt-0.5">B2B Projects</div>
      </div>
      <div class="text-center border-x border-slate-200 dark:border-slate-800">
        <div class="text-2xl font-black bg-gradient-to-r from-indigo-600 to-blue-600 dark:from-indigo-400 dark:to-blue-400 bg-clip-text text-transparent">+10</div>
        <div class="text-xs text-slate-500 dark:text-slate-500 mt-0.5">Years Avg. Exp.</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-black bg-gradient-to-r from-indigo-600 to-blue-600 dark:from-indigo-400 dark:to-blue-400 bg-clip-text text-transparent">99.9%</div>
        <div class="text-xs text-slate-500 dark:text-slate-500 mt-0.5">Uptime SLA</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce opacity-30 dark:opacity-40">
    <svg class="h-5 w-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </div>
</section>

<script>
  const runHeroAnimation = () => {
    const elements = [
      { sel: '.hero-badge', delay: 100 },
      { sel: '.hero-title', delay: 250 },
      { sel: '.hero-subtitle', delay: 400 },
      { sel: '.hero-tagline', delay: 500 },
      { sel: '.hero-ctas', delay: 600 },
      { sel: '.hero-tags', delay: 750 },
      { sel: '.hero-stats', delay: 900 },
      { sel: '.hero-code-block', delay: 700 },
      { sel: '.hero-stack-block', delay: 900 },
    ];
    elements.forEach(({ sel, delay }) => {
      const el = document.querySelector(sel) as HTMLElement | null;
      if (el) {
        setTimeout(() => {
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, delay);
      }
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', runHeroAnimation);
  } else {
    runHeroAnimation();
  }
</script>

<style>
  .hero-badge,
  .hero-title,
  .hero-subtitle,
  .hero-tagline,
  .hero-ctas,
  .hero-tags,
  .hero-stats {
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    transform: translateY(20px);
  }

  @keyframes float-orb {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(20px, -20px) scale(1.05); }
    66% { transform: translate(-15px, 10px) scale(0.97); }
  }
  .glow-orb { animation: float-orb 18s ease-in-out infinite; }
  .glow-orb-2 { animation: float-orb 22s ease-in-out infinite reverse; }
  .glow-orb-3 { animation: float-orb 15s ease-in-out infinite 5s; }
</style>
