---
import { locales, defaultLocale, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
  base?: string;
}

const { locale: currentLocale, base = '/portfolio-colab' } = Astro.props;

const homeUrl = (loc: Locale) => loc === defaultLocale ? `${base}/` : `${base}/${loc}/`;

const labels: Record<Locale, string> = {
  'en': 'English',
  'pt-pt': 'Português PT',
  'pt-br': 'Português BR',
  'fr': 'Français',
};
---

<div class="flex items-center gap-1 text-sm">
  {locales.map((loc, index) => (
    <>
      {index > 0 && <span class="text-slate-300 dark:text-slate-600">|</span>}
      <a
        href={homeUrl(loc)}
        class={`px-1.5 py-1 rounded transition-colors ${loc === currentLocale ? 'font-semibold text-indigo-600 dark:text-indigo-400' : 'text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300'}`}
        hreflang={loc}
        aria-current={loc === currentLocale ? 'page' : undefined}
      >
        {labels[loc]}
      </a>
    </>
  ))}
</div>
