---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);

const partners = [
  {
    linkedin: 'https://www.linkedin.com/in/van-romel-neto/',
    gradient: 'from-indigo-500 to-blue-600',
    initials: 'VN',
  },
  {
    linkedin: 'https://www.linkedin.com/in/rafael-carvalho-gomes-700752101/',
    gradient: 'from-emerald-500 to-teal-600',
    initials: 'RG',
  },
];
---

<section id="sobre" class="relative py-24 sm:py-32 bg-slate-50/50 dark:bg-slate-900/20">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 right-0 h-[300px] w-[300px] rounded-full bg-indigo-500/5 dark:bg-indigo-500/5 blur-[80px]"></div>
    <div class="absolute bottom-1/4 left-0 h-[250px] w-[250px] rounded-full bg-blue-500/5 dark:bg-blue-500/5 blur-[80px]"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center animate-on-scroll">
      <p class="text-sm font-semibold uppercase tracking-widest text-indigo-500 dark:text-indigo-400">{i18n.about.label}</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white">
        {i18n.about.title} <span class="bg-gradient-to-r from-indigo-500 to-blue-500 bg-clip-text text-transparent">{i18n.about.titleHighlight}</span>
      </h2>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        {i18n.about.subtitle}
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-2">
      <div class="animate-on-scroll stagger-1 rounded-2xl border border-slate-200/60 dark:border-slate-800/60 bg-white dark:bg-slate-900/50 p-8 hover:border-indigo-500/30 transition-all duration-500 hover:shadow-xl hover:shadow-indigo-500/5">
        <div class="flex items-center gap-4 mb-6">
          <a href={partners[0].linkedin} target="_blank" rel="noopener noreferrer" class={`h-16 w-16 rounded-2xl bg-gradient-to-br ${partners[0].gradient} flex items-center justify-center text-white font-bold text-lg shrink-0 shadow-lg hover:scale-105 transition-transform`}>
            {partners[0].initials}
          </a>
          <div>
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white">
              <a href={partners[0].linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-indigo-500 dark:hover:text-indigo-400 transition-colors">
                {i18n.about.dev1Name}
              </a>
            </h3>
            <p class="text-sm text-indigo-600 dark:text-indigo-400 font-medium">{i18n.about.dev1Role}</p>
          </div>
        </div>

        <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-6">
          {i18n.about.dev1Desc}
        </p>

        <div class="flex flex-wrap gap-2">
          {['Java', 'Kotlin', 'Spring Boot', 'Kubernetes', 'Azure', 'Docker', 'Terraform', 'PostgreSQL', 'CI/CD'].map((skill: string) => (
            <span class="inline-flex items-center rounded-lg bg-slate-100 dark:bg-slate-800/80 px-3 py-1 text-xs font-medium text-slate-700 dark:text-slate-300 hover:bg-indigo-50 dark:hover:bg-indigo-950/50 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors cursor-default">
              {skill}
            </span>
          ))}
        </div>
      </div>

      <div class="animate-on-scroll stagger-2 rounded-2xl border border-slate-200/60 dark:border-slate-800/60 bg-white dark:bg-slate-900/50 p-8 hover:border-indigo-500/30 transition-all duration-500 hover:shadow-xl hover:shadow-indigo-500/5">
        <div class="flex items-center gap-4 mb-6">
          <a href={partners[1].linkedin} target="_blank" rel="noopener noreferrer" class={`h-16 w-16 rounded-2xl bg-gradient-to-br ${partners[1].gradient} flex items-center justify-center text-white font-bold text-lg shrink-0 shadow-lg hover:scale-105 transition-transform`}>
            {partners[1].initials}
          </a>
          <div>
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white">
              <a href={partners[1].linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-indigo-500 dark:hover:text-indigo-400 transition-colors">
                {i18n.about.dev2Name}
              </a>
            </h3>
            <p class="text-sm text-indigo-600 dark:text-indigo-400 font-medium">{i18n.about.dev2Role}</p>
          </div>
        </div>

        <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-6">
          {i18n.about.dev2Desc}
        </p>

        <div class="flex flex-wrap gap-2">
          {['React', 'Angular', 'TypeScript', 'Node.js', 'Spring Boot', 'JavaScript', 'OutSystems', 'RPA'].map((skill: string) => (
            <span class="inline-flex items-center rounded-lg bg-slate-100 dark:bg-slate-800/80 px-3 py-1 text-xs font-medium text-slate-700 dark:text-slate-300 hover:bg-indigo-50 dark:hover:bg-indigo-950/50 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors cursor-default">
              {skill}
            </span>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-16 animate-on-scroll stagger-3">
      <div class="rounded-2xl border border-slate-200/60 dark:border-slate-800/60 bg-white dark:bg-slate-900/50 p-8 sm:p-10">
        <div class="grid gap-8 sm:grid-cols-3 text-center">
          <div>
            <p class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-indigo-500 to-blue-500 bg-clip-text text-transparent">+50</p>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{i18n.about.statsProjects}</p>
          </div>
          <div>
            <p class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-indigo-500 to-blue-500 bg-clip-text text-transparent">+8</p>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{i18n.about.statsExperience}</p>
          </div>
          <div>
            <p class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-indigo-500 to-blue-500 bg-clip-text text-transparent">99.9%</p>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{i18n.about.statsUptime}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
