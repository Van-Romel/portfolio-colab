---
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;

import '../styles/global.css';
import { localeHtmlLang } from '../i18n/utils';

const htmlLang = localeHtmlLang[locale];

const metaTitle = title || 'SC Tech Labs | Consultoria Software Engineering';
const metaDesc = description || 'Consultoria em engenharia de software. Spring Boot, Kubernetes, Azure, React, Angular. Projetos B2B escaláveis na Europa e América do Sul.';

const canonicalPath = locale === 'en' ? '/' : `/${locale}/`;
---

<!doctype html>
<html lang={htmlLang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{metaTitle}</title>
    <meta name="description" content={metaDesc} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`https://sctechlabs.com${canonicalPath}`} />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === 'pt' ? 'pt' : locale === 'en' ? 'en' : 'fr'} />
    <meta property="og:url" content={`https://sctechlabs.com${canonicalPath}`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
    <script is:inline>
      (function() {
        const savedLocale = sessionStorage.getItem('preferredLocale');
        if (!savedLocale) return;
        
        const currentPath = window.location.pathname;
        const base = '';
        
        // Detect current locale from path
        const localeMatch = currentPath.match(/^\/(en|pt|fr)(\/|$)/);
        const currentLocale = localeMatch ? localeMatch[1] : 'en';

        // If saved locale differs from current, redirect
        if (savedLocale !== currentLocale) {
          const hash = window.location.hash;
          const pathWithoutLocale = currentPath.replace(/^\/(en|pt|fr)?/, '').replace(/^\//, '') || '';
          
          let newPath;
          if (savedLocale === 'en') {
            newPath = pathWithoutLocale ? `${base}/${pathWithoutLocale}` : `${base}/`;
          } else {
            newPath = pathWithoutLocale ? `${base}/${savedLocale}/${pathWithoutLocale}` : `${base}/${savedLocale}/`;
          }
          
          window.location.replace(newPath + hash);
        }
      })();
    </script>
  </head>
  <body class="bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100 font-sans antialiased transition-colors duration-300">
    <slot />
    <script>
      function initScrollAnimations() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('animate-in');
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        document.querySelectorAll('.animate-on-scroll').forEach((el) => {
          observer.observe(el);
        });
      }

      initScrollAnimations();
      document.addEventListener('astro:after-swap', initScrollAnimations);
    </script>
  </body>
</html>
