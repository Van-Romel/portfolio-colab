---
const partners = [
  {
    name: 'Parceiro 1',
    role: 'Backend & DevOps Engineer',
    description: 'Especialista em arquiteturas distribuídas, microservices e cloud infrastructure. +8 anos de experiência com ecossistema Java e plataformas cloud enterprise.',
    skills: ['Java', 'Spring Boot', 'Kubernetes', 'Azure', 'Docker', 'Terraform', 'PostgreSQL', 'Redis'],
    gradient: 'from-indigo-500 to-blue-600',
    initials: 'BE',
  },
  {
    name: 'Parceiro 2',
    role: 'Full-Stack Developer',
    description: 'Desenvolvedor full-stack com forte enfoque em interfaces modernas e arquitetura frontend escalável. Experiência em projetos enterprise de grande escala.',
    skills: ['React', 'Angular', 'TypeScript', 'Node.js', 'Next.js', 'Tailwind CSS', 'GraphQL', 'MongoDB'],
    gradient: 'from-emerald-500 to-teal-600',
    initials: 'FS',
  },
];
---

<section id="sobre" class="relative py-24 sm:py-32 bg-slate-50/50 dark:bg-slate-900/20">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 right-0 h-[300px] w-[300px] rounded-full bg-indigo-500/5 dark:bg-indigo-500/5 blur-[80px]"></div>
    <div class="absolute bottom-1/4 left-0 h-[250px] w-[250px] rounded-full bg-blue-500/5 dark:bg-blue-500/5 blur-[80px]"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center animate-on-scroll">
      <p class="text-sm font-semibold uppercase tracking-widest text-indigo-500 dark:text-indigo-400">Equipa</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white">
        Quem <span class="bg-gradient-to-r from-indigo-500 to-blue-500 bg-clip-text text-transparent">Somos</span>
      </h2>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        Uma parceria freelance entre dois engenheiros apaixonados por tecnologia, baseados em Portugal.
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-2">
      {partners.map((partner, index) => (
        <div class={`animate-on-scroll stagger-${index + 1} rounded-2xl border border-slate-200/60 dark:border-slate-800/60 bg-white dark:bg-slate-900/50 p-8 hover:border-indigo-500/30 transition-all duration-500 hover:shadow-xl hover:shadow-indigo-500/5`}>
          <div class="flex items-center gap-4 mb-6">
            <div class={`h-16 w-16 rounded-2xl bg-gradient-to-br ${partner.gradient} flex items-center justify-center text-white font-bold text-lg shrink-0 shadow-lg`}>
              {partner.initials}
            </div>
            <div>
              <h3 class="text-xl font-semibold text-slate-900 dark:text-white">{partner.name}</h3>
              <p class="text-sm text-indigo-600 dark:text-indigo-400 font-medium">{partner.role}</p>
            </div>
          </div>

          <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-6">
            {partner.description}
          </p>

          <div class="flex flex-wrap gap-2">
            {partner.skills.map((skill: string) => (
              <span class="inline-flex items-center rounded-lg bg-slate-100 dark:bg-slate-800/80 px-3 py-1 text-xs font-medium text-slate-700 dark:text-slate-300 hover:bg-indigo-50 dark:hover:bg-indigo-950/50 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors cursor-default">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 animate-on-scroll stagger-3">
      <div class="rounded-2xl border border-slate-200/60 dark:border-slate-800/60 bg-white dark:bg-slate-900/50 p-8 sm:p-10">
        <div class="grid gap-8 sm:grid-cols-3 text-center">
          <div>
            <p class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-indigo-500 to-blue-500 bg-clip-text text-transparent">+50</p>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Projetos Entregues</p>
          </div>
          <div>
            <p class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-indigo-500 to-blue-500 bg-clip-text text-transparent">+8</p>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Anos de Experiência</p>
          </div>
          <div>
            <p class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-indigo-500 to-blue-500 bg-clip-text text-transparent">99.9%</p>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Uptime Garantido</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
