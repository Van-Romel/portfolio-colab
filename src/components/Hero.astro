---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);

const base = '/portfolio-colab';
const projectsUrl = locale === 'pt' ? `${base}/projetos/` : `${base}/${locale}/projetos/`;
---

<section id="home" class="relative h-[60vh] md:min-h-screen flex items-center justify-center pt-12 md:pt-16 pb-8 md:pb-12 bg-gradient-to-br from-slate-50 to-blue-50/50 dark:from-slate-900 dark:to-indigo-950/50">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 h-[300px] w-[300px] md:h-[500px] md:w-[500px] rounded-full bg-indigo-500/10 dark:bg-indigo-500/20 blur-[60px] md:blur-[100px]"></div>
    <div class="absolute -bottom-20 -left-20 h-[200px] w-[200px] md:h-[400px] md:w-[400px] rounded-full bg-blue-500/10 dark:bg-blue-500/20 blur-[50px] md:blur-[100px]"></div>
  </div>

  <div class="absolute inset-0 opacity-[0.015] dark:opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, currentColor 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
    <div class="animate-on-scroll">
      <div class="inline-flex items-center gap-2 rounded-full border border-indigo-500/20 bg-indigo-500/10 px-4 py-1.5 text-sm text-indigo-600 dark:text-indigo-400 mb-6 md:mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
        </span>
        {i18n.hero.badge}
      </div>
    </div>

    <h1 class="animate-on-scroll text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.15]">
      <span class="block text-slate-900 dark:text-white">{i18n.hero.title1}</span>
      <span class="block mt-2 bg-gradient-to-r from-indigo-500 via-blue-500 to-cyan-400 bg-clip-text text-transparent">{i18n.hero.title2}</span>
    </h1>

    <p class="animate-on-scroll stagger-1 mx-auto mt-6 max-w-2xl text-lg sm:text-xl text-slate-600 dark:text-slate-400 leading-relaxed">
      {i18n.hero.subtitle}
    </p>

    <div class="animate-on-scroll stagger-2 mt-8 md:mt-10 flex flex-col items-center justify-center gap-3 md:gap-4">
      <a href={projectsUrl} class="group w-full max-w-xs inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-blue-600 px-6 md:px-8 py-3 md:py-3.5 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 hover:shadow-indigo-500/40 transition-all duration-300 hover:-translate-y-0.5">
        {i18n.hero.cta1}
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
      <a href={`${locale === 'pt' ? base : `${base}/${locale}`}/#contato`} class="w-full max-w-xs inline-flex items-center justify-center gap-2 rounded-xl border border-slate-300 dark:border-slate-700 bg-white/50 dark:bg-slate-900/50 px-6 md:px-8 py-3 md:py-3.5 text-sm font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all duration-300 hover:-translate-y-0.5 backdrop-blur-sm">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        {i18n.hero.cta2}
      </a>
    </div>

    <div class="animate-on-scroll stagger-3 mt-6 md:mt-8 flex flex-wrap items-center justify-center gap-2 md:gap-3">
      {['Spring Boot', 'Kubernetes', 'Azure', 'React', 'Angular', 'Docker', 'CI/CD'].map(tech => (
        <span class="px-3 py-1.5 rounded-full border border-slate-200 dark:border-indigo-500/30 text-xs font-medium text-slate-500 dark:text-indigo-300 hover:border-indigo-500/50 hover:text-indigo-600 dark:hover:text-indigo-300 transition-colors cursor-default bg-white/50 dark:bg-indigo-500/10">
          {tech}
        </span>
      ))}
    </div>
  </div>

  <div class="absolute bottom-4 md:bottom-6 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="h-5 w-5 text-indigo-400 dark:text-indigo-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </div>
</section>
