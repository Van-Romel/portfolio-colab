---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);
---

<section id="worldwide" class="py-20 bg-gradient-to-b from-slate-900 to-indigo-900">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- SVG Rede Global Estática -->
    <svg viewBox="0 0 1200 600" class="w-full h-96 rounded-2xl shadow-2xl" aria-label="Global network map">
      <defs>
        <!-- Gradientes -->
        <radialGradient id="globeBg" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#1e3a8a"/>
          <stop offset="70%" stop-color="#312e81"/>
          <stop offset="100%" stop-color="#1e1b4b"/>
        </radialGradient>
        <linearGradient id="connectionGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#6366f1"/>
          <stop offset="50%" stop-color="#8b5cf6"/>
          <stop offset="100%" stop-color="#3b82f6"/>
        </linearGradient>
        <linearGradient id="pinEurope" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#fbbf24"/>
          <stop offset="100%" stop-color="#f59e0b"/>
        </linearGradient>
        <linearGradient id="pinSouth" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#f87171"/>
          <stop offset="100%" stop-color="#ef4444"/>
        </linearGradient>
        <linearGradient id="pinNorth" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#60a5fa"/>
          <stop offset="100%" stop-color="#3b82f6"/>
        </linearGradient>
        <!-- Glow filter -->
        <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="4" result="coloredBlur"/>
          <feMerge>
            <feMergeNode in="coloredBlur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
        <filter id="strongGlow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="8" result="coloredBlur"/>
          <feMerge>
            <feMergeNode in="coloredBlur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
      </defs>
      
      <!-- Fundo -->
      <rect width="1200" height="600" fill="url(#globeBg)" rx="16"/>
      
      <!-- Grade sutil de fundo -->
      <g opacity="0.1" stroke="#6366f1" stroke-width="0.5">
        <line x1="0" y1="100" x2="1200" y2="100"/>
        <line x1="0" y1="200" x2="1200" y2="200"/>
        <line x1="0" y1="300" x2="1200" y2="300"/>
        <line x1="0" y1="400" x2="1200" y2="400"/>
        <line x1="0" y1="500" x2="1200" y2="500"/>
        <line x1="200" y1="0" x2="200" y2="600"/>
        <line x1="400" y1="0" x2="400" y2="600"/>
        <line x1="600" y1="0" x2="600" y2="600"/>
        <line x1="800" y1="0" x2="800" y2="600"/>
        <line x1="1000" y1="0" x2="1000" y2="600"/>
      </g>
      
      <!-- Círculos concêntricos representando alcance global -->
      <circle cx="600" cy="300" r="150" fill="none" stroke="#6366f1" stroke-width="1" opacity="0.3"/>
      <circle cx="600" cy="300" r="200" fill="none" stroke="#6366f1" stroke-width="1" opacity="0.2"/>
      <circle cx="600" cy="300" r="250" fill="none" stroke="#6366f1" stroke-width="1" opacity="0.1"/>
      
      <!-- Linhas de conexão entre regiões -->
      <g stroke="url(#connectionGrad)" stroke-width="2" opacity="0.6" filter="url(#glow)">
        <!-- Europa -> US -->
        <line x1="580" y1="220" x2="850" y2="250"/>
        <!-- Europa -> América do Sul -->
        <line x1="580" y1="220" x2="720" y2="380"/>
        <!-- US -> América do Sul -->
        <line x1="850" y1="250" x2="720" y2="380"/>
        <!-- Europa -> Ásia -->
        <line x1="580" y1="220" x2="980" y2="280"/>
      </g>
      
      <!-- Pontos de dados nas conexões -->
      <g fill="#60a5fa" filter="url(#glow)">
        <circle cx="715" cy="235" r="3"/>
        <circle cx="650" cy="300" r="3"/>
        <circle cx="785" cy="315" r="3"/>
        <circle cx="780" cy="250" r="3"/>
      </g>
      
      <!-- Pin Europa (Portugal) -->
      <g transform="translate(580, 220)">
        <circle r="20" fill="url(#pinEurope)" opacity="0.3" filter="url(#strongGlow)"/>
        <circle r="12" fill="url(#pinEurope)" filter="url(#glow)"/>
        <circle r="6" fill="#fef3c7"/>
      </g>
      
      <!-- Pin América do Norte (US) -->
      <g transform="translate(850, 250)">
        <circle r="20" fill="url(#pinNorth)" opacity="0.3" filter="url(#strongGlow)"/>
        <circle r="12" fill="url(#pinNorth)" filter="url(#glow)"/>
        <circle r="6" fill="#dbeafe"/>
      </g>
      
      <!-- Pin América do Sul (Brasil) -->
      <g transform="translate(720, 380)">
        <circle r="20" fill="url(#pinSouth)" opacity="0.3" filter="url(#strongGlow)"/>
        <circle r="12" fill="url(#pinSouth)" filter="url(#glow)"/>
        <circle r="6" fill="#fee2e2"/>
      </g>
      
      <!-- Pin Ásia -->
      <g transform="translate(980, 280)">
        <circle r="15" fill="#8b5cf6" opacity="0.3" filter="url(#strongGlow)"/>
        <circle r="9" fill="#8b5cf6" filter="url(#glow)"/>
        <circle r="4" fill="#ede9fe"/>
      </g>
      
      <!-- Ícones de representação -->
      <g opacity="0.8">
        <!-- Ícone cloud/server no centro -->
        <g transform="translate(600, 300)" filter="url(#glow)">
          <rect x="-25" y="-15" width="50" height="30" rx="8" fill="#1e40af" stroke="#60a5fa" stroke-width="2"/>
          <circle cx="-10" cy="0" r="4" fill="#60a5fa"/>
          <circle cx="0" cy="0" r="4" fill="#60a5fa"/>
          <circle cx="10" cy="0" r="4" fill="#60a5fa"/>
        </g>
      </g>
      
      <!-- Labels das regiões -->
      <g font-family="Inter, sans-serif" font-size="14" font-weight="500" text-anchor="middle">
        <text x="580" y="190" fill="#fbbf24" filter="url(#glow)">{i18n.worldwide.europe}</text>
        <text x="850" y="220" fill="#60a5fa" filter="url(#glow)">{i18n.worldwide.northAmerica}</text>
        <text x="720" y="420" fill="#f87171" filter="url(#glow)">{i18n.worldwide.southAmerica}</text>
        <text x="980" y="310" fill="#a78bfa" filter="url(#glow)">Asia</text>
      </g>
    </svg>
    
    <!-- Texto abaixo -->
    <div class="text-center mt-8">
      <p class="text-xl md:text-2xl text-indigo-200 font-medium tracking-wide">
        {i18n.worldwide.subtitle}
      </p>
    </div>
  </div>
</section>
