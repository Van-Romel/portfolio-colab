---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);
---

<section id="services" class="py-16 md:py-32 relative overflow-hidden bg-gradient-to-br from-slate-50 via-blue-50/80 to-indigo-50 dark:from-indigo-900/95 dark:via-blue-900/70 dark:to-indigo-900/90">
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 md:mb-16">
      <h2 class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white mb-4">
        {i18n.services.title}
      </h2>
      <div class="h-1 w-24 bg-gradient-to-r from-indigo-500 to-blue-500 mx-auto rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      <!-- Card 1: Consulting -->
      <div class="group bg-white/80 dark:bg-slate-800/70 backdrop-blur-xl border border-slate-200/50 dark:border-indigo-500/40 rounded-3xl p-8 shadow-2xl hover:border-indigo-400/70 dark:hover:border-indigo-400/70 transition-all duration-300 hover:scale-[1.02]">
        <div class="h-12 w-12 rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 flex items-center justify-center mb-5 shadow-lg shadow-indigo-500/25">
          <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714a2.25 2.25 0 01-.659 1.591L9.75 14.5M9.75 3.104c-1.251.118-2.5.304-3.75.55M12 14.5v-3.75m0 3.75l2.25 2.25M12 14.5l-2.25 2.25M12 14.5v-3.75m0 3.75l2.25 2.25M12 14.5l-2.25 2.25" />
          </svg>
        </div>
        <h3 class="text-xl md:text-2xl font-bold text-slate-900 dark:text-white mb-3">
          {i18n.services.consulting}
        </h3>
        <p class="text-slate-600 dark:text-slate-300 text-sm md:text-base leading-relaxed">
          {i18n.services.desc1}
        </p>
      </div>

      <!-- Card 2: End-to-End -->
      <div class="group bg-white/80 dark:bg-slate-800/70 backdrop-blur-xl border border-slate-200/50 dark:border-indigo-500/40 rounded-3xl p-8 shadow-2xl hover:border-indigo-400/70 dark:hover:border-indigo-400/70 transition-all duration-300 hover:scale-[1.02]">
        <div class="h-12 w-12 rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 flex items-center justify-center mb-5 shadow-lg shadow-indigo-500/25">
          <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        </div>
        <h3 class="text-xl md:text-2xl font-bold text-slate-900 dark:text-white mb-3">
          {i18n.services.end2end}
        </h3>
        <p class="text-slate-600 dark:text-slate-300 text-sm md:text-base leading-relaxed">
          {i18n.services.desc2}
        </p>
      </div>

      <!-- Card 3: Freelance -->
      <div class="group bg-white/80 dark:bg-slate-800/70 backdrop-blur-xl border border-slate-200/50 dark:border-indigo-500/40 rounded-3xl p-8 shadow-2xl hover:border-indigo-400/70 dark:hover:border-indigo-400/70 transition-all duration-300 hover:scale-[1.02]">
        <div class="h-12 w-12 rounded-xl bg-gradient-to-br from-indigo-600 to-blue-600 flex items-center justify-center mb-5 shadow-lg shadow-indigo-500/25">
          <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
        </div>
        <h3 class="text-xl md:text-2xl font-bold text-slate-900 dark:text-white mb-3">
          {i18n.services.freelance}
        </h3>
        <p class="text-slate-600 dark:text-slate-300 text-sm md:text-base leading-relaxed">
          {i18n.services.desc3}
        </p>
      </div>
    </div>
  </div>
</section>
