---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Projects from '../components/Projects.astro';
import Footer from '../components/Footer.astro';
import { t } from '../i18n/utils';

const locale = 'pt-pt';
const i18n = t(locale);
---

<Layout locale={locale} title={`${i18n.nav.projects} | SC Tech Labs`} description={i18n.meta.description}>
  <Header locale={locale} />
  <main class="pt-16">
    <div class="py-16 bg-gradient-to-b from-indigo-50/50 to-transparent dark:from-indigo-950/20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white">
          {i18n.nav.projects}
        </h1>
        <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
          {i18n.projects.subtitle}
        </p>
      </div>
    </div>
    <Projects locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
