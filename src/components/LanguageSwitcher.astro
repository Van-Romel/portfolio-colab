---
import { locales, localeLabels, localeFlags, localeNames, defaultLocale, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
  base?: string;
}

const { locale: currentLocale, base = '/portfolio-colab' } = Astro.props;

const baseUrl = `${base}/`;

const localeUrls: Record<Locale, string> = {
  'pt-pt': `${baseUrl}`,
  'en': `${baseUrl}en/`,
  'pt-br': `${baseUrl}pt-br/`,
  'fr': `${baseUrl}fr/`,
};
---

<div class="relative group">
  <button
    type="button"
    class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
    aria-haspopup="listbox"
    aria-expanded="false"
    id="lang-btn"
  >
    <span class="text-base">{localeFlags[currentLocale]}</span>
    <span>{localeLabels[currentLocale]}</span>
    <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </button>

  <div class="absolute right-0 mt-1 w-40 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
    <div class="py-1">
      {locales.map((loc) => (
        <a
          href={localeUrls[loc]}
          class={`flex items-center gap-3 px-4 py-2 text-sm ${loc === currentLocale ? 'bg-indigo-50 dark:bg-indigo-950/50 text-indigo-600 dark:text-indigo-400 font-medium' : 'text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800'}`}
          hreflang={loc}
        >
          <span class="text-base">{localeFlags[loc]}</span>
          <span>{localeNames[loc]}</span>
        </a>
      ))}
    </div>
  </div>
</div>
