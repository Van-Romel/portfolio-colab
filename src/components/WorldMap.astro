---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);
---

<section id="worldwide" class="relative py-24 sm:py-32 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/4 h-[400px] w-[400px] rounded-full bg-indigo-500/5 dark:bg-indigo-500/5 blur-[100px]"></div>
    <div class="absolute bottom-1/4 right-1/4 h-[300px] w-[300px] rounded-full bg-blue-500/5 dark:bg-blue-500/5 blur-[80px]"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center animate-on-scroll mb-16">
      <p class="text-sm font-semibold uppercase tracking-widest text-indigo-500 dark:text-indigo-400">{i18n.worldwide.label}</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white">
        {i18n.worldwide.title} <span class="bg-gradient-to-r from-indigo-500 to-blue-500 bg-clip-text text-transparent">{i18n.worldwide.titleHighlight}</span>
      </h2>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        {i18n.worldwide.text}
      </p>
    </div>

    <div class="relative mx-auto max-w-5xl animate-on-scroll">
      <div class="aspect-[2/1] relative">
        <svg id="world-map" class="w-full h-full" viewBox="0 0 1000 500" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="oceanGradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" class="text-slate-100 dark:text-slate-900" stop-color="currentColor" />
              <stop offset="100%" class="text-slate-200 dark:text-slate-800" stop-color="currentColor" />
            </linearGradient>
            <linearGradient id="landGradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" class="text-indigo-400 dark:text-indigo-600" stop-color="currentColor" />
              <stop offset="100%" class="text-blue-500 dark:text-blue-700" stop-color="currentColor" />
            </linearGradient>
            <linearGradient id="landGradientLight" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" class="text-indigo-300 dark:text-indigo-500" stop-color="currentColor" />
              <stop offset="100%" class="text-blue-400 dark:text-blue-600" stop-color="currentColor" />
            </linearGradient>
            <linearGradient id="particleGradient" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#6366f1" />
              <stop offset="100%" stop-color="#3b82f6" />
            </linearGradient>
            <filter id="glow">
              <feGaussianBlur stdDeviation="4" result="coloredBlur"/>
              <feMerge>
                <feMergeNode in="coloredBlur"/>
                <feMergeNode in="SourceGraphic"/>
              </feMerge>
            </filter>
            <filter id="softGlow">
              <feGaussianBlur stdDeviation="8" result="coloredBlur"/>
              <feMerge>
                <feMergeNode in="coloredBlur"/>
                <feMergeNode in="SourceGraphic"/>
              </feMerge>
            </filter>
          </defs>

          <rect width="1000" height="500" fill="url(#oceanGradient)" rx="24" />

          <!-- North America - curved organic shape -->
          <path class="world-land" fill="url(#landGradient)" opacity="0.7" filter="url(#softGlow)"
            d="M30,60 
               C60,40 140,35 200,45 
               C260,55 300,80 280,120 
               C270,150 250,160 220,170
               C200,180 160,175 140,190
               C120,200 100,220 80,210
               C50,195 40,160 35,130
               C28,100 20,80 30,60 Z" />
          
          <!-- North America detail overlay -->
          <path class="world-land" fill="url(#landGradientLight)" opacity="0.4"
            d="M50,80
               C80,70 150,65 190,75
               C230,85 260,100 240,130
               C230,150 200,155 170,160
               C140,165 110,175 90,165
               C65,155 55,130 50,105
               C45,90 42,85 50,80 Z" />

          <!-- South America - curved organic shape -->
          <path class="world-land" fill="url(#landGradient)" opacity="0.7" filter="url(#softGlow)"
            d="M210,200
               C230,190 280,185 300,205
               C320,225 315,260 300,290
               C285,320 270,360 250,390
               C230,415 200,410 185,380
               C170,350 175,310 185,280
               C195,250 200,220 210,200 Z" />

          <!-- South America detail -->
          <path class="world-land" fill="url(#landGradientLight)" opacity="0.4"
            d="M230,220
               C250,215 285,220 290,245
               C295,270 285,300 270,330
               C255,360 235,375 220,360
               C205,340 210,300 220,270
               C225,245 225,230 230,220 Z" />

          <!-- Europe - more detailed curved shape -->
          <path class="world-land" fill="url(#landGradient)" opacity="0.7" filter="url(#softGlow)"
            d="M400,95
               C420,85 480,80 520,90
               C550,100 560,130 540,155
               C525,175 490,180 460,175
               C430,170 410,160 400,145
               C390,130 385,115 390,105
               C395,98 398,96 400,95 Z" />

          <!-- Europe detail -->
          <path class="world-land" fill="url(#landGradientLight)" opacity="0.4"
            d="M420,110
               C440,105 490,105 510,115
               C525,125 520,145 500,155
               C480,165 450,160 430,150
               C415,140 412,125 420,110 Z" />

          <!-- Africa - detailed organic shape -->
          <path class="world-land" fill="url(#landGradient)" opacity="0.7" filter="url(#softGlow)"
            d="M420,180
               C440,170 500,165 530,180
               C560,195 570,230 555,270
               C540,310 520,350 490,370
               C460,390 430,380 415,350
               C400,320 395,280 405,250
               C412,220 415,195 420,180 Z" />

          <!-- Africa detail -->
          <path class="world-land" fill="url(#landGradientLight)" opacity="0.4"
            d="M450,200
               C470,195 510,200 525,220
               C535,245 525,280 510,310
               C495,340 470,355 450,340
               C430,320 435,280 445,250
               C450,225 452,210 450,200 Z" />

          <!-- Asia - large detailed shape -->
          <path class="world-land" fill="url(#landGradient)" opacity="0.7" filter="url(#softGlow)"
            d="M540,70
               C580,55 680,50 750,60
               C820,70 880,100 900,140
               C915,180 890,220 840,240
               C790,260 720,265 660,250
               C610,235 580,210 560,180
               C545,155 540,125 545,95
               C542,82 541,75 540,70 Z" />

          <!-- Asia detail -->
          <path class="world-land" fill="url(#landGradientLight)" opacity="0.4"
            d="M580,90
               C620,80 720,75 780,90
               C830,105 860,135 850,170
               C840,205 790,225 730,220
               C670,215 620,195 600,165
               C585,140 582,115 580,90 Z" />

          <!-- Australia - curved shape -->
          <path class="world-land" fill="url(#landGradient)" opacity="0.7" filter="url(#softGlow)"
            d="M780,300
               C800,290 860,285 890,300
               C920,315 930,350 910,375
               C890,400 850,405 810,395
               C775,385 760,360 765,335
               C770,315 775,305 780,300 Z" />

          <!-- Australia detail -->
          <path class="world-land" fill="url(#landGradientLight)" opacity="0.4"
            d="M810,320
               C830,315 870,320 885,335
               C895,355 885,375 865,380
               C840,385 810,375 805,355
               C800,340 805,328 810,320 Z" />

          <!-- Connection hub glows -->
          <circle cx="420" cy="130" r="30" fill="#6366f1" opacity="0.15" filter="url(#softGlow)">
            <animate attributeName="r" values="30;45;30" dur="3s" repeatCount="indefinite" />
            <animate attributeName="opacity" values="0.15;0.08;0.15" dur="3s" repeatCount="indefinite" />
          </circle>
          <circle cx="250" cy="300" r="25" fill="#6366f1" opacity="0.15" filter="url(#softGlow)">
            <animate attributeName="r" values="25;38;25" dur="3s" repeatCount="indefinite" begin="1s" />
            <animate attributeName="opacity" values="0.15;0.08;0.15" dur="3s" repeatCount="indefinite" begin="1s" />
          </circle>

          <!-- Location markers -->
          <g class="markers">
            <!-- Europe (Portugal) -->
            <circle cx="420" cy="130" r="8" fill="#6366f1" filter="url(#glow)">
              <animate attributeName="r" values="8;11;8" dur="2s" repeatCount="indefinite" />
              <animate attributeName="opacity" values="1;0.6;1" dur="2s" repeatCount="indefinite" />
            </circle>
            <!-- South America (Brazil) -->
            <circle cx="250" cy="300" r="8" fill="#6366f1" filter="url(#glow)">
              <animate attributeName="r" values="8;11;8" dur="2s" repeatCount="indefinite" begin="0.5s" />
              <animate attributeName="opacity" values="1;0.6;1" dur="2s" repeatCount="indefinite" begin="0.5s" />
            </circle>
            <!-- North America -->
            <circle cx="150" cy="120" r="5" fill="#3b82f6" opacity="0.9">
              <animate attributeName="r" values="5;7;5" dur="2.5s" repeatCount="indefinite" />
            </circle>
            <!-- Asia -->
            <circle cx="720" cy="150" r="5" fill="#3b82f6" opacity="0.9">
              <animate attributeName="r" values="5;7;5" dur="2.5s" repeatCount="indefinite" begin="0.7s" />
            </circle>
          </g>

          <!-- Animated particle paths with curves -->
          <g class="particle-paths" stroke="url(#particleGradient)" stroke-width="2.5" fill="none" opacity="0.7" stroke-linecap="round">
            <!-- Europe to North America -->
            <path id="path-eu-na" d="M420,130 C350,110 250,100 150,120" stroke-dasharray="10,5" />
            <!-- Europe to South America -->
            <path id="path-eu-sa" d="M420,130 C380,200 320,260 250,300" stroke-dasharray="10,5" />
            <!-- Europe to Asia -->
            <path id="path-eu-asia" d="M420,130 C520,135 620,140 720,150" stroke-dasharray="10,5" />
            <!-- South America to North America -->
            <path id="path-sa-na" d="M250,300 C200,220 180,140 150,120" stroke-dasharray="10,5" />
            <!-- North America to Asia (via Europe route feel) -->
            <path id="path-na-asia" d="M150,120 C300,115 500,130 720,150" stroke-dasharray="10,5" />
          </g>

          <!-- Animated particles -->
          <g class="particles" fill="#6366f1" filter="url(#glow)">
            <circle r="4">
              <animateMotion dur="3s" repeatCount="indefinite">
                <mpath href="#path-eu-na" />
              </animateMotion>
            </circle>
            <circle r="4">
              <animateMotion dur="3.5s" repeatCount="indefinite" begin="0.5s">
                <mpath href="#path-eu-sa" />
              </animateMotion>
            </circle>
            <circle r="4">
              <animateMotion dur="2.5s" repeatCount="indefinite" begin="1s">
                <mpath href="#path-eu-asia" />
              </animateMotion>
            </circle>
            <circle r="4">
              <animateMotion dur="3s" repeatCount="indefinite" begin="1.5s">
                <mpath href="#path-sa-na" />
              </animateMotion>
            </circle>
            <circle r="4">
              <animateMotion dur="4s" repeatCount="indefinite" begin="2s">
                <mpath href="#path-na-asia" />
              </animateMotion>
            </circle>
          </g>

          <!-- Pulse rings -->
          <g class="pulse-rings" fill="none" stroke="#6366f1" stroke-width="2.5">
            <circle cx="420" cy="130" r="12" opacity="0">
              <animate attributeName="r" values="12;35" dur="2.5s" repeatCount="indefinite" />
              <animate attributeName="opacity" values="0.6;0" dur="2.5s" repeatCount="indefinite" />
              <animate attributeName="stroke-width" values="2.5;0.5" dur="2.5s" repeatCount="indefinite" />
            </circle>
            <circle cx="250" cy="300" r="12" opacity="0">
              <animate attributeName="r" values="12;35" dur="2.5s" repeatCount="indefinite" begin="1.2s" />
              <animate attributeName="opacity" values="0.6;0" dur="2.5s" repeatCount="indefinite" begin="1.2s" />
              <animate attributeName="stroke-width" values="2.5;0.5" dur="2.5s" repeatCount="indefinite" begin="1.2s" />
            </circle>
          </g>
        </svg>
      </div>

      <!-- Region labels with i18n -->
      <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
        <div class="p-4 rounded-xl bg-slate-50/50 dark:bg-slate-900/50 border border-slate-200/60 dark:border-slate-800/60 hover:border-indigo-300 dark:hover:border-indigo-700 transition-colors">
          <p class="text-sm font-medium text-slate-900 dark:text-white">{i18n.worldwide.europe}</p>
          <p class="text-xs text-slate-500 dark:text-slate-400">{i18n.worldwide.europeSub}</p>
        </div>
        <div class="p-4 rounded-xl bg-slate-50/50 dark:bg-slate-900/50 border border-slate-200/60 dark:border-slate-800/60 hover:border-indigo-300 dark:hover:border-indigo-700 transition-colors">
          <p class="text-sm font-medium text-slate-900 dark:text-white">{i18n.worldwide.southAmerica}</p>
          <p class="text-xs text-slate-500 dark:text-slate-400">{i18n.worldwide.southAmericaSub}</p>
        </div>
        <div class="p-4 rounded-xl bg-slate-50/50 dark:bg-slate-900/50 border border-slate-200/60 dark:border-slate-800/60 hover:border-indigo-300 dark:hover:border-indigo-700 transition-colors">
          <p class="text-sm font-medium text-slate-900 dark:text-white">{i18n.worldwide.northAmerica}</p>
          <p class="text-xs text-slate-500 dark:text-slate-400">{i18n.worldwide.northAmericaSub}</p>
        </div>
        <div class="p-4 rounded-xl bg-slate-50/50 dark:bg-slate-900/50 border border-slate-200/60 dark:border-slate-800/60 hover:border-indigo-300 dark:hover:border-indigo-700 transition-colors">
          <p class="text-sm font-medium text-slate-900 dark:text-white">{i18n.worldwide.asiaPacific}</p>
          <p class="text-xs text-slate-500 dark:text-slate-400">{i18n.worldwide.asiaPacificSub}</p>
        </div>
      </div>
    </div>
  </div>
</section>
