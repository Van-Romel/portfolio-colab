---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);
---

<section id="global" class="relative py-24 sm:py-32 bg-slate-50/50 dark:bg-slate-900/20">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 right-0 h-[300px] w-[300px] rounded-full bg-indigo-500/5 dark:bg-indigo-500/5 blur-[80px]"></div>
    <div class="absolute bottom-1/4 left-0 h-[250px] w-[250px] rounded-full bg-blue-500/5 dark:bg-blue-500/5 blur-[80px]"></div>
    <div class="absolute top-1/2 left-1/3 h-[200px] w-[200px] rounded-full bg-cyan-500/5 dark:bg-cyan-500/5 blur-[60px]"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center animate-on-scroll">
      <p class="text-sm font-semibold uppercase tracking-widest text-indigo-500 dark:text-indigo-400">{i18n.globalReach.label}</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white">
        {i18n.globalReach.title} <span class="bg-gradient-to-r from-indigo-500 to-blue-500 bg-clip-text text-transparent">{i18n.globalReach.titleHighlight}</span>
      </h2>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        {i18n.globalReach.subtitle}
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-3">
      <div class="animate-on-scroll stagger-1 rounded-2xl border border-slate-200/60 dark:border-slate-800/60 bg-white dark:bg-slate-900/50 p-8 text-center hover:border-indigo-500/30 transition-all duration-500 hover:shadow-xl hover:shadow-indigo-500/5">
        <div class="mx-auto h-16 w-16 rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center mb-5 shadow-lg">
          <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">{i18n.globalReach.europe}</h3>
        <p class="text-sm text-slate-600 dark:text-slate-400">{i18n.globalReach.europeDesc}</p>
      </div>

      <div class="animate-on-scroll stagger-2 rounded-2xl border border-slate-200/60 dark:border-slate-800/60 bg-white dark:bg-slate-900/50 p-8 text-center hover:border-indigo-500/30 transition-all duration-500 hover:shadow-xl hover:shadow-indigo-500/5">
        <div class="mx-auto h-16 w-16 rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center mb-5 shadow-lg">
          <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">{i18n.globalReach.southAmerica}</h3>
        <p class="text-sm text-slate-600 dark:text-slate-400">{i18n.globalReach.southAmericaDesc}</p>
      </div>

      <div class="animate-on-scroll stagger-3 rounded-2xl border border-slate-200/60 dark:border-slate-800/60 bg-white dark:bg-slate-900/50 p-8 text-center hover:border-indigo-500/30 transition-all duration-500 hover:shadow-xl hover:shadow-indigo-500/5">
        <div class="mx-auto h-16 w-16 rounded-2xl bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center mb-5 shadow-lg">
          <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21L21 3.75M3.75 3.75L21 21" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25z" stroke-opacity="0" />
            <circle cx="12" cy="12" r="9" stroke-width="1.5" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 2.25v19.5M2.25 12h19.5" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">{i18n.globalReach.worldwide}</h3>
        <p class="text-sm text-slate-600 dark:text-slate-400">{i18n.globalReach.worldwideDesc}</p>
      </div>
    </div>

    <div class="mt-12 animate-on-scroll stagger-4">
      <div class="rounded-2xl overflow-hidden h-64 border border-slate-200 dark:border-slate-800">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d12111.84778826836!2d-7.7746!3d40.6043!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd2312a29a1d3b7f%3A0x400ebbde4903a60!2sMangualde%2C%20Portugal!5e0!3m2!1sen!2spt!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="SC Tech Labs - Mangualde, Portugal">
        </iframe>
      </div>
    </div>
  </div>
</section>
